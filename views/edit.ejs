<% layout("/layouts/boilerplate") %>

<div class="container mt-5" style="text-align:center;">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-primary text-white text-center">
          <h3>Edit Listing</h3>
        </div>
        <div class="card-body p-4">
          <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" >
            
            <!-- Title -->
            <div class="mb-3">
              <label class="form-label fw-bold">Title</label>
              <input 
                value="<%= listing.title %>" 
                name="listing[title]" 
                type="text" 
                class="form-control" 
                required >
            </div>

            <!-- Description -->
            <div class="mb-3">
              <label class="form-label fw-bold">Description</label>
              <textarea 
                name="listing[description]" 
                class="form-control" 
                rows="3"
                required><%= listing.description %></textarea>
            </div>
             <div class="mb-3">
               <h3> Old image  </h3>
               
               <img src="<%=originalImageUrl%>"  style="margin-left: -20px;"  >
             
              </div>

            <!-- Image -->
            <div class="mb-3">
              <label class="form-label fw-bold">Image URL</label>
              <input 
                value="<%= listing.image%>" 
                name="listing[filename][image]" 
                type="text" 
                class="form-control"
                 required>
             
            </div>

            <!-- Price -->
            <div class="mb-3">
              <label class="form-label fw-bold">Price (₹)</label>
              <input 
                value="<%= listing.price %>" 
                name="listing[price]" 
                type="number" 
                class="form-control"
                min="0"
                required>
            </div>

            <!-- Location -->
            <div class="mb-3">
              <label class="form-label fw-bold">Location</label>
              <input 
                value="<%= listing.location %>" 
                name="listing[location]" 
                type="text" 
                class="form-control"
                required>
            </div>

            <!-- Country -->
            <div class="mb-3">
              <label class="form-label fw-bold">Country</label>
              <input 
                value="<%= listing.country %>" 
                name="listing[country]" 
                type="text" 
                class="form-control"
                required>
            </div>

            <!-- Submit Button -->
            <div class="d-grid">
              <button type="submit" class="btn btn-success btn-lg">
                Update Listing
              </button>
            </div>

          </form>
        </div>
      </div>
    </div>
  </div>
</div>
